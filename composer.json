{
    "name":"bright-cloud-studio/contao-isotope-cumulative-filter",
    "description":"Extends Isotope's Cumulative Filter to use deterministic MD5 hashes in URLs, preventing search engine robots from crawling infinite unique pages.",
    "keywords": ["contao", "isotope", "cumulative", "filter", "bright", "cloud", "studio"],
    "type": "contao-bundle",
    "homepage": "https://brightcloudstudio.com/",
    "license": "LGPL-3.0+",
    "authors":[
        {
            "name": "Bright Cloud Studio",
            "homepage": "https://brightcloudstudio.com",
            "email": "mark@brightcloudstudio.com",
            "role": "Developer"
        }
    ],
    "support":{
        "issues": "https://github.com/bright-cloud-studio/contao-isotope-cumulative-filter/issues",
        "source": "https://github.com/bright-cloud-studio/contao-isotope-cumulative-filter"
    },
    "require":{
        "php": "^7.4 || ^8.0",
        "contao/core-bundle": "^4.13 || ^5.3"
    },
    "extra":{
        "contao-manager-plugin": "Bcs\\IsotopeCumulativeFilterBundle\\ContaoManager\\Plugin"
    },
    "autoload": {
        "psr-4": {
            "Bcs\\IsotopeCumulativeFilterBundle\\": "src"
        },
        "classmap": [
            "src/Resources/contao"
        ],
        "exclude-from-classmap": [
            "src/Resources/contao/config/",
            "src/Resources/contao/dca/",
            "src/Resources/contao/languages/",
            "src/Resources/contao/templates/"
        ]
    }
}
